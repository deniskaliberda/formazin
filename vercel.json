{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "rm -rf .next && NEXT_TURBOPACK=0 next build --no-turbopack",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.formazin-partner.de" }],
      "destination": "https://formazin-partner.de/:path",
      "permanent": true
    }
  ]
}
